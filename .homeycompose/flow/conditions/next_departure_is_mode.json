{
  "title": { "en": "Next departure !{{is|is not}} ..." },
  "titleFormatted": { "en": "Next departure !{{is|is not}} [[mode]]" },
  "hint": { "en": "Checks if the next departure's transport mode matches the selected mode." },
  "args": [
    {
      "type": "device",
      "name": "device",
      "filter": "driver_id=norwegian-public-transport"
    },
    {
      "type": "dropdown",
      "name": "mode",
      "values": [
        { "id": "bus", "label": { "en": "Bus" } },
        { "id": "metro", "label": { "en": "Metro" } },
        { "id": "tram", "label": { "en": "Tram" } },
        { "id": "rail", "label": { "en": "Rail" } },
        { "id": "water", "label": { "en": "Water" } },
        { "id": "air", "label": { "en": "Air" } },
        { "id": "coach", "label": { "en": "Coach" } }
      ]
    }
  ]
}
